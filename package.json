{
  "name": "boomtown",
  "version": "0.1.0",
  "description": "A tower-building sim (SimTower / Project Highrise style), architected to become a multiplayer shared-city game.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
